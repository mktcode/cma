# Optional. Defaults to ./.cma inside the project directory.
CMA_DATA_DIR=

# Poll interval for the gateway loop in seconds.
POLL_SECONDS=60

# Telegram is enabled only when both values are set.
TELEGRAM_TOKEN=
TELEGRAM_ALLOWED_IDS=12345,67890

# Email is enabled only when both values are set.
EMAIL_ALLOWED=me@example.com,you@example.com
MAIL_FROM=bot@example.com